---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const dateFmt: Intl.DateTimeFormatOptions = {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
};
---

<BaseLayout
  title="Peter Keppeler"
  description="Backend and infrastructure engineer. Notes on systems, code, and the work."
>
  <section>
    <h1>Peter Keppeler</h1>
    <p>
      Backend and infrastructure engineer. Currently at
      <a href="https://pryzm.com">Pryzm</a>. Previously
      <a href="https://www.vannevarlabs.com">Vannevar Labs</a> and
      <a href="https://www.palantir.com">Palantir</a>.
    </p>
    <p>
      {/* TODO: replace placeholder links with real profiles before publishing. */}
      <a href="https://github.com/pkeppeler">github</a> &middot;
      <a href="#TODO-twitter">twitter</a> &middot;
      <a href="#TODO-linkedin">linkedin</a> &middot;
      <a href="mailto:TODO@example.com">email</a>
    </p>
  </section>

  <section>
    <h2>recent writing</h2>
    {posts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul class="posts">
        {posts.map((post) => (
          <li>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', dateFmt)}
            </time>
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    )}
    <p><a href="/posts/">all posts &rarr;</a></p>
  </section>
</BaseLayout>
